## Backend environment (copy to .env on your server)
##
## IMPORTANT:
## - Never commit your real `.env` to git (it is already ignored).
## - Fill in AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY from IAM access keys.

# --- AWS / S3 (required for video uploads) ---
S3_BUCKET=crickcoach-ai-videos
AWS_REGION=ap-south-2

# Optional base prefix inside the bucket (no leading/trailing slashes)
S3_BASE_PREFIX=uploads

# Credentials (required on DigitalOcean / outside AWS)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# --- Gemini / Google AI (required for AI features) ---
# Prefer GEMINI_API_KEY. GOOGLE_API_KEY is accepted as a fallback.
GEMINI_API_KEY=""

# --- YouTube Data API (optional: resolves drill queries to specific watch URLs) ---
# If unset, the backend will return YouTube search URLs instead of watch URLs.
YOUTUBE_API_KEY=""
# Max drills per plan to resolve to watch URLs (quota/latency safety).
YOUTUBE_RESOLVE_MAX="12"

